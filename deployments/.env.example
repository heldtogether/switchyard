# Environment variables for Docker Swarm stack deployment
# Copy this file to .env and customize for your environment
# These variables are used by stack.yml

# =============================================================================
# Version & Registry
# =============================================================================
VERSION=latest
DOCKER_REGISTRY=ghcr.io/heldtogether

# =============================================================================
# Database Configuration (External Postgres)
# =============================================================================
# Full connection string to your external Postgres instance
DATABASE_URL=postgres://jobrunner:PASSWORD@postgres-host:5432/jobrunner?sslmode=require

# =============================================================================
# S3 Storage Configuration
# =============================================================================
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=jobrunner
S3_REGION=us-east-1

# =============================================================================
# Service Scaling
# =============================================================================
API_REPLICAS=2
WORKER_REPLICAS=2
WORKER_CONCURRENCY=5

# =============================================================================
# Logging
# =============================================================================
LOGGING_LEVEL=info
